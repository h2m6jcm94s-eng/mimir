{
  "name": "@mimir/cli",
  "version": "0.0.1",
  "private": true,
  "description": "Mimir terminal control and scripting CLI",
  "main": "./dist/index.js",
  "bin": {
    "mimir": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format cjs --dts --clean",
    "dev": "tsx src/cli.ts",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.0.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
