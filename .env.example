# Mimir environment template
# Copy to .env and fill in real values. Never commit .env.

# Node / web
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# API
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mimir
REDIS_URL=redis://localhost:6379
TEMPORAL_HOST=localhost:7233
TEMPORAL_TASK_QUEUE=mimir-task-queue
LIBSQL_URL=file:./data/state.db

# Worker (optional; defaults shown)
WORKER_HEALTH_PORT=3002

# Models (add only the providers you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
KIMI_API_KEY=
# Optional: override default base URL (Kimi Code keys default to https://api.kimi.com/coding/v1)
KIMI_BASE_URL=

# Model routing per privacy tier. Format: provider[:model],provider[:model]
# Examples:
#   MODEL_PROVIDER_T0=local
#   MODEL_PROVIDER_T1=kimi:kimi-for-coding,openai:gpt-4o-mini
#   MODEL_PROVIDER_T2=anthropic:claude-3-5-sonnet-20241022,kimi:kimi-for-coding
MODEL_PROVIDER_T0=
MODEL_PROVIDER_T1=
MODEL_PROVIDER_T2=

# Tailscale / mesh
TAILSCALE_AUTH_KEY=

# Cloud worker (optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
