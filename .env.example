# Mimir environment template
# Copy to .env and fill in real values. Never commit .env.

# Node / web
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# API
PORT=3001
# Sandbox mode: 'gvisor' (required in production), 'passthrough' (dev only), or unset for auto-detect.
SANDBOX_MODE=
DATABASE_URL=postgresql://mimir_app:mimir_app@localhost:5432/mimir
REDIS_URL=redis://localhost:6379
TEMPORAL_HOST=localhost:7233
TEMPORAL_TASK_QUEUE=mimir-task-queue
LIBSQL_URL=file:./data/state.db
# Embedded replica streaming (required in production; optional for local dev).
# Point at the libsql-primary container/service and provide a JWT auth token.
LIBSQL_SYNC_URL=http://localhost:8081
LIBSQL_AUTH_TOKEN=
# Embedded replica encryption. REQUIRED in production; optional in dev/test.
LIBSQL_ENCRYPTION_KEY=
# Local replica lifecycle: prune finished jobs older than N days and VACUUM periodically.
LIBSQL_RETENTION_DAYS=30
LIBSQL_VACUUM_INTERVAL_MS=3600000
LIBSQL_INTEGRITY_INTERVAL_MS=3600000
# In production, a disk-full/I/O write error on the replica exits the process.
LIBSQL_WRITE_FAILURE_FATAL=

# Fencing clock-skew guard: reject epoch bumps/promotions if wall clock jumps more than N ms.
CLOCK_SKEW_THRESHOLD_MS=5000

# Auth (Supertokens self-hosted)
SUPERTOKENS_CONNECTION_URI=http://localhost:3567
SUPERTOKENS_API_KEY=change-me-in-production
AUTH_DOMAIN=http://localhost:3001
WEB_APP_DOMAIN=http://localhost:3000

# Worker (optional; defaults shown)
WORKER_HEALTH_PORT=3002

# Email digest delivery (SMTP)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@mimir.local

# Auto circuit-breaker: emergency halt when daily model spend crosses this USD threshold
# AUTO_HALT_DAILY_USD=10

# Per-action cost ceiling: a single projected action above this USD threshold halts the tenant
# MAX_TASK_COST_USD=5

# Telemetry redaction: when enabled, scrub T0 prompts/payloads from logs and hash payload keys
# TELEMETRY_REDACT_T0=1

# Models (add only the providers you use)
# In production these should be loaded from a vault instead of .env. Supported
# vault aliases: model-provider:{openai,kimi,groq,qwen,anthropic}:{api-key,base-url}
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
KIMI_API_KEY=
# Optional: override default base URL (Kimi Code keys default to https://api.kimi.com/coding/v1)
KIMI_BASE_URL=

# Model routing per privacy tier. Format: provider[:model],provider[:model]
# When T0 is empty, Mimir defaults to the bundled Mimir Local model (Ollama-based).
# Examples:
#   MODEL_PROVIDER_T0=mimir-local
#   MODEL_PROVIDER_T1=kimi:kimi-for-coding,openai:gpt-4o-mini
#   MODEL_PROVIDER_T2=anthropic:claude-3-5-sonnet-20241022,kimi:kimi-for-coding
MODEL_PROVIDER_T0=
MODEL_PROVIDER_T1=
MODEL_PROVIDER_T2=

# Tailscale / mesh
TAILSCALE_AUTH_KEY=

# Cloud worker (optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Prefer storing this in the vault as the alias 'cloud-worker-secret'.
CLOUD_WORKER_SECRET=
CLOUD_WORKER_AMI_ID=
CLOUD_WORKER_INSTANCE_TYPE=t3.micro
CLOUD_WORKER_WEBHOOK_BASE_URL=
# Hardened networking is required in production. Use the SG/IAM/Subnet from infra/terraform/cloud-worker/.
CLOUD_WORKER_SECURITY_GROUP_IDS=
CLOUD_WORKER_SUBNET_ID=
CLOUD_WORKER_IAM_INSTANCE_PROFILE=

# Secrets vault (production requires one of these backends)
# HashiCorp Vault:
VAULT_ADDR=
VAULT_TOKEN=
VAULT_MOUNT=secret
# File-encrypted vault:
VAULT_FILE_PATH=
VAULT_FILE_PASSPHRASE=

# SSH CA (optional; generate/rotate keys with scripts/ssh-ca-init.sh and scripts/ssh-ca-rotate.sh)
# To store encrypted private keys, set AGE_RECIPIENT and use the .age path here.
SSH_CA_USER_PRIVATE_KEY_FILE=
SSH_CA_HOST_PRIVATE_KEY_FILE=

# Backups (encrypted by default with age)
# Set AGE_RECIPIENT to a public age key, or BACKUP_UNENCRYPTED=1 for plaintext (dev only).
AGE_RECIPIENT=
BACKUP_UNENCRYPTED=0

# Restore / SSH CA age decryption
AGE_IDENTITY=

# CLI config encryption (optional but recommended)
MIMIR_CLI_PASSPHRASE=

# Groq (OpenAI-compatible, optional)
GROQ_API_KEY=
GROQ_BASE_URL=

# Notion OAuth public integration (optional; leave blank to use internal integration tokens only)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
# Must match the redirect URI registered in notion.so/my-integrations (e.g. http://localhost:3000/connectors/notion/callback)
NOTION_OAUTH_REDIRECT_URI=
