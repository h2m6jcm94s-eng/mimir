# Mimir environment template
# Copy to .env and fill in real values. Never commit .env.

# Node / web
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# API
PORT=3001
DATABASE_URL=postgresql://mimir_app:mimir_app@localhost:5432/mimir
REDIS_URL=redis://localhost:6379
TEMPORAL_HOST=localhost:7233
TEMPORAL_TASK_QUEUE=mimir-task-queue
LIBSQL_URL=file:./data/state.db

# Auth (Supertokens self-hosted)
SUPERTOKENS_CONNECTION_URI=http://localhost:3567
SUPERTOKENS_API_KEY=change-me-in-production
AUTH_DOMAIN=http://localhost:3001
WEB_APP_DOMAIN=http://localhost:3000

# Worker (optional; defaults shown)
WORKER_HEALTH_PORT=3002

# Auto circuit-breaker: emergency halt when daily model spend crosses this USD threshold
# AUTO_HALT_DAILY_USD=10

# Models (add only the providers you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
KIMI_API_KEY=
# Optional: override default base URL (Kimi Code keys default to https://api.kimi.com/coding/v1)
KIMI_BASE_URL=

# Model routing per privacy tier. Format: provider[:model],provider[:model]
# Examples:
#   MODEL_PROVIDER_T0=local
#   MODEL_PROVIDER_T1=kimi:kimi-for-coding,openai:gpt-4o-mini
#   MODEL_PROVIDER_T2=anthropic:claude-3-5-sonnet-20241022,kimi:kimi-for-coding
MODEL_PROVIDER_T0=
MODEL_PROVIDER_T1=
MODEL_PROVIDER_T2=

# Tailscale / mesh
TAILSCALE_AUTH_KEY=

# Cloud worker (optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CLOUD_WORKER_SECRET=
CLOUD_WORKER_AMI_ID=
CLOUD_WORKER_INSTANCE_TYPE=t3.micro
CLOUD_WORKER_WEBHOOK_BASE_URL=

# Secrets vault
VAULT_ADDR=
VAULT_TOKEN=
VAULT_MOUNT=secret
VAULT_FILE_PATH=
VAULT_FILE_PASSPHRASE=

# SSH CA (optional; generate keys with scripts/ssh-ca-init.sh)
SSH_CA_USER_PRIVATE_KEY_FILE=
SSH_CA_HOST_PRIVATE_KEY_FILE=

# LibSQL replica encryption (optional)
LIBSQL_ENCRYPTION_KEY=

# Groq (OpenAI-compatible, optional)
GROQ_API_KEY=
GROQ_BASE_URL=
